// Geometry:
//   Room: 7 m x 5 m x 3 m
//   x = length, y = width, z = height
//
// Boundary patches created here:
//   supplyTiles  : three cold-air inlet tiles on the floor, z = 0
//   returnOutlet : ceiling outlet strip, z = 3
//   floor        : remaining floor
//   ceiling      : remaining ceiling
//   walls        : all four vertical side walls
//
// Rack heat-source regions are NOT solid blocks in v0.1.
// Create rack cellZones with topoSet and apply heat with constant/fvModels.

convertToMeters  1;

// ------------------------------------------------------------------------- //
// Grid-independence control
// ------------------------------------------------------------------------- //
// Change ONLY these three values for coarse/base/fine meshes.
// They are cells per metre in x, y, z. 10 10 10 reproduces the original
// approximately uniform 0.1 m grid: about 70 x 50 x 30 cells.
//
// Suggested grid-independence levels:
//   coarse : cellsPerMetreX 7;  cellsPerMetreY 7;  cellsPerMetreZ 7;
//   base   : cellsPerMetreX 10; cellsPerMetreY 10; cellsPerMetreZ 10;
//   fine   : cellsPerMetreX 14; cellsPerMetreY 14; cellsPerMetreZ 14;
//
// You can also refine vertically more strongly, e.g. 10 10 14, if buoyant
// thermal plumes or ceiling stratification need better resolution.

cellsPerMetreX    14;
cellsPerMetreY    14;
cellsPerMetreZ    14;

// Cell counts for x-segments. The x break-points are:
// 0, 0.5, 1.0, 1.8, 3.1, 3.9, 5.2, 6.0, 6.5, 7.0
