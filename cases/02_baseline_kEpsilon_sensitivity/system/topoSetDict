FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}

// Creates six rack cellZones for heat-source application in constant/fvModels.
// Run after blockMesh:
//     topoSet

actions
(
    // Left rack row: 1.0 <= y <= 2.0
    {
        name    rack_L1_cells;
        type    cellSet;
        action  new;
        source  boxToCell;
        sourceInfo
        {
            box (1.0 1.0 0.0) (1.8 2.0 2.2);
        }
    }
    {
        name    rack_L1;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        sourceInfo
        {
            set rack_L1_cells;
        }
    }

    {
        name    rack_L2_cells;
        type    cellSet;
        action  new;
        source  boxToCell;
        sourceInfo
        {
            box (3.1 1.0 0.0) (3.9 2.0 2.2);
        }
    }
    {
        name    rack_L2;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        sourceInfo
        {
            set rack_L2_cells;
        }
    }

    {
        name    rack_L3_cells;
        type    cellSet;
        action  new;
        source  boxToCell;
        sourceInfo
        {
            box (5.2 1.0 0.0) (6.0 2.0 2.2);
        }
    }
    {
        name    rack_L3;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        sourceInfo
        {
            set rack_L3_cells;
        }
    }

    // Right rack row: 3.0 <= y <= 4.0
    {
        name    rack_R1_cells;
        type    cellSet;
        action  new;
        source  boxToCell;
        sourceInfo
