FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application     foamRun;
solver          fluid;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         8000;

deltaT          1;

writeControl    timeStep;
writeInterval   1000;

purgeWrite      0;

writeFormat     ascii;
writePrecision  7;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

adjustTimeStep  no;
maxCo           2;

